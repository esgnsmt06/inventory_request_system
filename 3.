# TEST 4: Ürün Oluşturma Testi (Yetkili/Yetkisiz)
# =========================================================================
def test_product_creation(app, client):
    """Yalnızca admin/manager rolündeki kullanıcıların ürün oluşturabildiğini doğrular."""
    with app.app_context():
        _, _, _, _ = setup_test_data()
    
    # Normal kullanıcı (ahmet) olarak giriş yapıp ürün eklemeyi dene
    client.get('/test_login/ahmet')
    res = client.post('/inventory/add', data={
        'name': 'Yeni Laptop',
        'category_id': 1,
        'quantity': 10,
        'critical_stock_level': 3,
        'location': 'A-Depo',
        'description': 'Yeni Nesil Laptop'
    })
    # Yetkisiz erişim olduğu için 403 hatası dönmeli
    assert res.status_code == 403
    
    # Envanter Sorumlusu (selin) olarak giriş yapıp ürün eklemeyi dene
    client.get('/test_login/selin')
    res = client.post('/inventory/add', data={
        'name': 'Yeni Laptop',
        'category_id': 1,
        'quantity': 10,
        'critical_stock_level': 3,
        'location': 'A-Depo',
        'description': 'Yeni Nesil Laptop'
    })
    # Başarılı eklemeden sonra envanter sayfasına yönlendirmeli (302)
    assert res.status_code == 302
    
    with app.app_context():
        item = db.session.scalar(db.select(InventoryItem).where(InventoryItem.name == 'Yeni Laptop'))
        assert item is not None
        assert item.quantity == 10
        assert item.location == 'A-Depo'


