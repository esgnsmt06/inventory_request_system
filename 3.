# TEST 5: Talep Oluşturma Testi (Miktar Sınırları ve Stok Aşımı)
# =========================================================================
def test_request_creation_and_limits(app, client):
    """Miktarı <= 0 olan taleplerin engellendiğini, stok aşımında ise uyarı verildiğini test eder."""
    with app.app_context():
        _, _, _, item_id = setup_test_data()
        
    client.get('/test_login/ahmet')
    
    # 0 veya negatif miktarlı talep (Redirect olmalı ve hata vermeli)
    res = client.post('/requests/create', data={'item_id': item_id, 'quantity': 0})
    assert res.status_code == 302 # redirect to details/inventory
    
    # Mevcut stoktan fazla miktar talep etme (Stok aşımı - redirect olmalı ve pending olarak eklenmeli)
    res = client.post('/requests/create', data={'item_id': item_id, 'quantity': 10})
    assert res.status_code == 302
    
    with app.app_context():
        req = db.session.get(InventoryRequest, 1)
        assert req is not None
        assert req.quantity == 10
        assert req.status == 'pending'


