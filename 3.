# TEST 2: Şifre Hash Testi
# =========================================================================
def test_password_hashing(app):
    """Şifrelerin açık metin olarak saklanmadığını ve doğrulamanın çalıştığını test eder."""
    with app.app_context():
        user = User(username="testuser", email="test@test.com")
        user.set_password("GuvenliSifre456")
        
        # Açık metin olmamalı
        assert user.password_hash != "GuvenliSifre456"
        
        # Doğru şifre geçmeli, yanlış şifre kalmalı
        assert user.check_password("GuvenliSifre456") is True
        assert user.check_password("YanlisSifre") is False


