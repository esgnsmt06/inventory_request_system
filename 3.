import pytest
from app import db
from app.models import User, Department, Category, InventoryItem, InventoryRequest, RequestLog

def setup_test_data():
    """Yardımcı fonksiyon: Testlerin ortak kullanabileceği temel verileri oluşturur."""
    it_dept = Department(name="IT")
    db.session.add(it_dept)
    
    emp1 = User(username="ahmet", email="ahmet@sirket.com", role="user", department=it_dept)
    emp1.set_password("sifre123")
    db.session.add(emp1)
    
    emp2 = User(username="mehmet", email="mehmet@sirket.com", role="user", department=it_dept)
    emp2.set_password("sifre123")
    db.session.add(emp2)
    
    manager = User(username="selin", email="selin@sirket.com", role="inventory_manager", department=it_dept)
    manager.set_password("sifre123")
    db.session.add(manager)
    
    cat = Category(name="Elektronik")
    db.session.add(cat)
    
    # 5 adet stoklu ürün
    item = InventoryItem(name="Kablosuz Mouse", quantity=5, critical_stock_level=2, category=cat)
    db.session.add(item)
    
    db.session.commit()
    return emp1.id, emp2.id, manager.id, item.id


