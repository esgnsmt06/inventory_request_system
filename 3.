    with app.app_context():
        req = db.session.get(InventoryRequest, 1)
        assert req.status == 'pending' # Onay engellenmiş olmalı, durum pending kalmalı


# =========================================================================
# TEST 7: Talep Reddetmede manager_note Zorunluluğu Testi
# =========================================================================
def test_request_rejection_validation(app, client):
    """Talep reddedilirken manager_note belirtilmemişse işlemin reddedildiğini test eder."""
    with app.app_context():
        _, _, _, item_id = setup_test_data()
        
    # Ahmet talep oluşturur
    client.get('/test_login/ahmet')
    client.post('/requests/create', data={'item_id': item_id, 'quantity': 2})
    
    # Selin (yönetici) giriş yapar
    client.get('/test_login/selin')
    
    # Boş açıklama ile reddetmeyi dene (durum pending kalmalı)
    client.post('/requests/1/reject', data={'manager_note': '   '})
    with app.app_context():
        req = db.session.get(InventoryRequest, 1)
        assert req.status == 'pending'
    
    # Açıklama ekleyerek reddet
    client.post('/requests/1/reject', data={'manager_note': 'Yeterli bütçe kalmadı.'})
    with app.app_context():
        req = db.session.get(InventoryRequest, 1)
        assert req.status == 'rejected'
        assert req.manager_note == 'Yeterli bütçe kalmadı.'


# =========================================================================
# TEST 8: Talep Sahipliği ve İptal/Erişim Kontrolü Testi
# =========================================================================
def test_request_ownership_cancellation(app, client):
    """Kullanıcının sadece kendi talebini iptal edebildiğini, başkasınınkine erişemediğini doğrular."""
    with app.app_context():
        _, _, _, item_id = setup_test_data()
        
    # Mehmet olarak giriş yapıp bir talep oluştur
    client.get('/test_login/mehmet')
    client.post('/requests/create', data={'item_id': item_id, 'quantity': 1}) # Req ID: 1
    
    # Ahmet olarak giriş yap
    client.get('/test_login/ahmet')
    
    # Ahmet, Mehmet'in talebini iptal etmeyi denesin (HTTP 403 Forbidden olmalı)
    res = client.post('/requests/1/cancel')
    assert res.status_code == 403
    
    # Ahmet, Mehmet'in talebinin detaylarına erişmeyi denesin (HTTP 403 Forbidden olmalı)
    res = client.get('/requests/1')
    assert res.status_code == 403


# =========================================================================
# TEST 9: Otomatik Loglama (Event Listener) Testi
# =========================================================================
def test_request_auto_logging(app, client):
    """Talep durum geçişlerinin (oluşturulma, onaylanma) otomatik loglandığını kontrol eder."""
    with app.app_context():
        _, _, _, item_id = setup_test_data()
        
    # Ahmet talep oluşturur (Durum: pending)
    client.get('/test_login/ahmet')
    client.post('/requests/create', data={'item_id': item_id, 'quantity': 2}) # Req ID: 1
    
    with app.app_context():
        req = db.session.get(InventoryRequest, 1)
        assert req is not None
        # Başlangıç log kaydı oluşmuş olmalı
        assert len(req.logs) == 1
        assert req.logs[0].new_status == "pending"
        assert "oluşturuldu" in req.logs[0].note
        
    # Selin onaylar (Durum: pending -> approved)
    client.get('/test_login/selin')
    client.post('/requests/1/approve')
    
    with app.app_context():
        req = db.session.get(InventoryRequest, 1)
        # Onay logu eklenmiş olmalı (toplam 2 log)
        assert len(req.logs) == 2
        assert req.logs[1].old_status == "pending"
        assert req.logs[1].new_status == "approved"
        assert "onaylandı" in req.logs[1].note

