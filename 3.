# TEST 1: Kullanıcı Kayıt Testi
# =========================================================================
def test_user_registration(app):
    """Kullanıcının veritabanına başarıyla kaydedilebildiğini doğrular."""
    with app.app_context():
        it_dept = Department(name="İnsan Kaynakları")
        db.session.add(it_dept)
        
        user = User(username="can", email="can@sirket.com", role="user", department=it_dept)
        user.set_password("parola123")
        db.session.add(user)
        db.session.commit()
        
        saved_user = db.session.scalar(db.select(User).where(User.username == "can"))
        assert saved_user is not None
        assert saved_user.email == "can@sirket.com"
        assert saved_user.department.name == "İnsan Kaynakları"


