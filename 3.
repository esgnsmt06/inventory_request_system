# TEST 6: Stok Kontrol Testi (Yetersiz Stok Durumunda Onay Engeli)
# =========================================================================
def test_request_insufficient_stock(app, client):
    """Talep edilen miktar envanter stoğundan büyükse onayın engellendiğini doğrular."""
    with app.app_context():
        _, _, _, item_id = setup_test_data()
        
    # Ahmet olarak giriş yapıp 10 adet Kablosuz Mouse talep et (Stokta sadece 5 var)
    client.get('/test_login/ahmet')
    client.post('/requests/create', data={'item_id': item_id, 'quantity': 10})
    
    # Yönetici (selin) olarak giriş yap
    client.get('/test_login/selin')
    
    # Stoğu aşan talebi onaylamayı dene (yönlendirme yapmalı ve status approved olmamalı)
