def check_manager_or_admin():
    """Giriş yapan kullanıcının yetkisini kontrol eder."""
    if not current_user.is_authenticated or current_user.role not in ['admin', 'inventory_manager']:
        abort(403)  # Yetkisiz erişim durumunda HTTP 403 Forbidden fırlatır

@inventory_bp.route('/')
@login_required
def index():
    """Arama ve sayfalama destekli olarak envanter listesini şablon üzerinde gösterir."""
    page = request.args.get('page', 1, type=int)
    search_query = request.args.get('q', '', type=str).strip()
    per_page = 5  # Sayfa başına ürün adedi
    
    # Arama kriterini SQL sorgusuna ekle
    stmt = db.select(InventoryItem)
    if search_query:
        stmt = stmt.where(
            InventoryItem.name.contains(search_query) | 
            InventoryItem.description.contains(search_query)
        )
        
    # Toplam eleman ve sayfa sayısını hesaplama
    total_items = db.session.scalar(db.select(db.func.count()).select_from(stmt.subquery())) or 0
    pages = max(1, (total_items + per_page - 1) // per_page)
    
    # Sayfa sınırlarına göre ürünleri çek
    items = db.session.scalars(
        stmt.order_by(InventoryItem.name).offset((page - 1) * per_page).limit(per_page)
    ).all()
    
    # Yeni ürün modalındaki kategori dropdown listesi için tüm kategorileri çek
    categories = db.session.scalars(db.select(Category).order_by(Category.name)).all()
    
    return render_template(
        'inventory.html',
        items=items,
        page=page,
        pages=pages,
        search_query=search_query,
        categories=categories
    )

@inventory_bp.route('/<int:item_id>')
@login_required
def details(item_id):
    """Belirli bir envanter kaleminin detaylarını gösterir."""
    item = db.session.get(InventoryItem, item_id)
    if not item:
        abort(404)
    return f"Item Details: Name={item.name}, Stock={item.quantity}, Category={item.category.name}, IsCritical={item.is_critical}, Location={item.location}"

@inventory_bp.route('/add', methods=['POST'])
@login_required
def add_item():
    """
    Yeni envanter kalemi ekler (Yalnızca admin veya inventory_manager).
    Formlarda CSRF koruması Flask-WTF ile otomatik olarak aktiftir.
    """
    check_manager_or_admin()
    
    name = request.form.get('name')
    category_id = request.form.get('category_id')
    quantity = request.form.get('quantity', type=int, default=0)
    critical_stock_level = request.form.get('critical_stock_level', type=int, default=5)
    location = request.form.get('location')
    description = request.form.get('description')
    
    if not name or not category_id:
        return "Hata: Ürün adı ve kategori ID zorunludur.", 400
        
    category = db.session.get(Category, category_id)
    if not category:
        return "Hata: Geçersiz kategori ID.", 400
        
    new_item = InventoryItem(
        name=name,
        category=category,
        quantity=quantity,
        critical_stock_level=critical_stock_level,
        location=location,
        description=description
    )
    db.session.add(new_item)
    db.session.commit()
    
    flash(f"Başarılı: Envanter kalemi '{new_item.name}' eklendi.", "success")
    return redirect(url_for('inventory.index'))

@inventory_bp.route('/categories', methods=['GET', 'POST'])
@login_required
def manage_categories():
    """Kategorileri listeler ve yeni kategori eklenmesini sağlar (Yalnızca admin/manager)."""
    check_manager_or_admin()
    
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        description = request.form.get('description', '').strip()
        
        if not name:
            flash("Hata: Kategori adı boş olamaz.", "danger")
            return redirect(url_for('inventory.manage_categories'))
            
        # Mükerrer kontrolü
        existing_cat = db.session.scalar(db.select(Category).where(Category.name == name))
        if existing_cat:
            flash(f"Hata: '{name}' adında bir kategori zaten mevcut.", "danger")
            return redirect(url_for('inventory.manage_categories'))
            
        new_cat = Category(name=name, description=description)
        db.session.add(new_cat)
        db.session.commit()
        
        flash(f"Başarılı: '{name}' kategorisi eklendi.", "success")
        return redirect(url_for('inventory.manage_categories'))
        
    categories = db.session.scalars(db.select(Category).order_by(Category.name)).all()
    return render_template('inventory/categories.html', categories=categories)

@inventory_bp.route('/categories/<int:category_id>/delete', methods=['POST'])
@login_required
def delete_category(category_id):
    """Kategoriyi siler (Eğer kategoriye bağlı ürün yoksa)."""
    check_manager_or_admin()
    
    category = db.session.get(Category, category_id)
    if not category:
        abort(404)
        
    # Eğer kategoriye bağlı ürün varsa silmeyi engelle
    if len(category.items) > 0:
        flash("Hata: Bu kategoriye bağlı envanter ürünleri bulunduğu için silinemez.", "danger")
        return redirect(url_for('inventory.manage_categories'))
        
    db.session.delete(category)
    db.session.commit()
    
    flash(f"Başarılı: '{category.name}' kategorisi silindi.", "success")
    return redirect(url_for('inventory.manage_categories'))


