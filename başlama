from flask import render_template, redirect, url_for, flash, request, abort
from flask_login import login_required, current_user
from app.blueprints.requests import requests_bp
from app import db
from app.models import InventoryRequest, InventoryItem, RequestLog

def check_manager_or_admin():
    """Giriş yapan kullanıcının yetkisini kontrol eder."""
    if not current_user.is_authenticated or current_user.role not in ['admin', 'inventory_manager']:
        abort(403)  # Yetkisiz erişim durumunda HTTP 403 Forbidden fırlatır

@requests_bp.route('/')
@login_required
def index():
    """
    Talepleri listeler.
    Admin ve yöneticiler tüm talepleri görebilir, 
    normal kullanıcılar yalnızca kendi taleplerini görebilir.
    """
    page = request.args.get('page', 1, type=int)
    status_filter = request.args.get('status', '', type=str)
    per_page = 10
    
    # Rol kontrolüne göre sorgu oluştur
    if current_user.role in ['admin', 'inventory_manager']:
        stmt = db.select(InventoryRequest)
    else:
        stmt = db.select(InventoryRequest).where(InventoryRequest.user_id == current_user.id)
        
    if status_filter:
        stmt = stmt.where(InventoryRequest.status == status_filter)
        
    # Tarihe göre tersten sırala (en yeni en üstte)
    stmt = stmt.order_by(InventoryRequest.created_at.desc())
    
    # Pagination
    total_requests = db.session.scalar(db.select(db.func.count()).select_from(stmt.subquery())) or 0
    pages = max(1, (total_requests + per_page - 1) // per_page)
    
    requests_list = db.session.scalars(
        stmt.offset((page - 1) * per_page).limit(per_page)
    ).all()
        
    return render_template(
        'requests/index.html',
        requests=requests_list,
        page=page,
        pages=pages,
        status_filter=status_filter
    )

@requests_bp.route('/<int:request_id>')
@login_required
def details(request_id):
    """
    Belirli bir talebin detaylarını gösterir.
    Kullanıcı kendi talebi olmayan bir talebe erişmeye çalışırsa 403 döner.
    """
    req = db.session.get(InventoryRequest, request_id)
    if not req:
        abort(404)
        
    # Güvenlik Kuralı: Normal kullanıcı başkasının talebine erişirse 403 döner
    if req.user_id != current_user.id and current_user.role not in ['admin', 'inventory_manager']:
        abort(403)
        
    return render_template('requests/details.html', req=req)

@requests_bp.route('/create', methods=['GET', 'POST'])
@login_required
def create_request():
    """
    Yeni bir envanter talebi oluşturur.
    İş Kuralı: Talep miktarı <= 0 olamaz.
    İş Kuralı: Talep miktarı mevcut stoktan fazla olabilir; ancak sistem kullanıcıyı uyarmalıdır.
    """
    if request.method == 'POST':
        item_id = request.form.get('item_id', type=int)
        quantity = request.form.get('quantity', type=int)
        request_note = request.form.get('request_note', '')
        
        if not item_id or quantity is None:
            flash("Hata: Ürün ve miktar alanları zorunludur.", "danger")
            return redirect(url_for('inventory.index'))
            
        # İş Kuralı: Talep miktarı <= 0 olamaz
        if quantity <= 0:
            flash("Hata: Talep miktarı 0 veya daha küçük olamaz.", "danger")
            return redirect(url_for('inventory.details', item_id=item_id))
            
        item = db.session.get(InventoryItem, item_id)
        if not item:
            flash("Hata: Geçersiz ürün seçimi.", "danger")
            return redirect(url_for('inventory.index'))
            
        # İş Kuralı: Talep miktarı mevcut stoktan fazla olabilir; ancak sistem kullanıcıyı uyarmalıdır.
        if quantity > item.quantity:
            flash("Uyarı: Talep ettiğiniz miktar mevcut stoktan fazladır. Talebiniz onay beklemektedir.", "warning")
            
        # Yeni talebin oluşturulması
        new_request = InventoryRequest(
            user=current_user,
            item=item,
            quantity=quantity,
            request_note=request_note,
            status='pending'
        )
        
        db.session.add(new_request)
        db.session.commit()
        
        flash(f"Talep başarıyla oluşturuldu: {item.name} ({quantity} adet).", "success")
        return redirect(url_for('requests.index'))
        
    # GET isteğinde doğrudan ürün listesiyle form göster
    items = db.session.scalars(db.select(InventoryItem).order_by(InventoryItem.name)).all()
    selected_item_id = request.args.get('item_id', type=int)
    return render_template('requests/create.html', items=items, selected_item_id=selected_item_id)

@requests_bp.route('/<int:request_id>/approve', methods=['POST'])
@login_required
def approve_request(request_id):
    """
    Talebi onaylar (Yalnızca admin ve inventory_manager).
    İş Kuralı: Stok yetersizse onay engellenmeli.
    """
    check_manager_or_admin()
    
    req = db.session.get(InventoryRequest, request_id)
    if not req:
        abort(404)
        
    if req.status != 'pending':
        flash(f"Hata: Yalnızca beklemede (pending) olan talepler onaylanabilir. Mevcut durum: {req.status}", "danger")
        return redirect(url_for('requests.details', request_id=request_id))
        
    # İş Kuralı: Stok yetersizse onay engellenmeli
    if req.quantity > req.item.quantity:
        flash(f"Hata: Yetersiz stok! Talep edilen: {req.quantity}, Mevcut Stok: {req.item.quantity}", "danger")
        return redirect(url_for('requests.details', request_id=request_id))
        
    # Stok azaltılması ve durumun güncellenmesi
    req.item.quantity -= req.quantity
    req._status_change_notes = f"Talep onaylandı. Stoktan {req.quantity} adet düşüldü. İşlemi yapan: {current_user.username} ({current_user.role})"
    req.status = 'approved'
    
    db.session.commit()
    
    flash(f"Talep #{req.id} onaylandı. Envanter stoğu güncellendi.", "success")
    return redirect(url_for('requests.details', request_id=request_id))

@requests_bp.route('/<int:request_id>/reject', methods=['POST'])
@login_required
def reject_request(request_id):
    """
    Talebi reddeder (Yalnızca admin ve inventory_manager).
    İş Kuralı: Reddetmede manager_note alanı zorunlu olmalıdır.
    """
    check_manager_or_admin()
    
    req = db.session.get(InventoryRequest, request_id)
    if not req:
        abort(404)
        
    if req.status != 'pending':
        flash(f"Hata: Yalnızca beklemede (pending) olan talepler reddedilebilir. Mevcut durum: {req.status}", "danger")
        return redirect(url_for('requests.details', request_id=request_id))
        
    manager_note = request.form.get('manager_note')
    
    # İş Kuralı: Reddetmede manager_note zorunlu olmalıdır
    if not manager_note or not manager_note.strip():
        flash("Hata: Talep reddedilirken ret gerekçesi (Yönetici Notu) belirtilmesi zorunludur.", "danger")
        return redirect(url_for('requests.details', request_id=request_id))
        
    req.manager_note = manager_note.strip()
    req._status_change_notes = f"Talep reddedildi. Ret Nedeni: {manager_note.strip()} - İşlemi yapan: {current_user.username}"
    req.status = 'rejected'
    
    db.session.commit()
    
    flash(f"Talep #{req.id} reddedildi.", "warning")
    return redirect(url_for('requests.details', request_id=request_id))

@requests_bp.route('/<int:request_id>/deliver', methods=['POST'])
@login_required
def deliver_request(request_id):
    """
    Talebi teslim edildi olarak işaretler (Yalnızca admin ve inventory_manager).
    İş Kuralı: Sadece onaylanmış (approved) talepler delivered yapılabilir.
    """
    check_manager_or_admin()
    
    req = db.session.get(InventoryRequest, request_id)
    if not req:
        abort(404)
        
    if req.status != 'approved':
        flash(f"Hata: Yalnızca onaylanmış (approved) talepler teslim edilebilir. Mevcut durum: {req.status}", "danger")
        return redirect(url_for('requests.details', request_id=request_id))
        
    req._status_change_notes = f"Talep teslim edildi olarak işaretlendi. İşlemi yapan: {current_user.username}"
    req.status = 'delivered'
    
    db.session.commit()
    
    flash(f"Talep #{req.id} teslim edildi olarak işaretlendi.", "success")
    return redirect(url_for('requests.details', request_id=request_id))

@requests_bp.route('/<int:request_id>/cancel', methods=['POST'])
@login_required
def cancel_request(request_id):
    """
    Talebi iptal eder.
    İş Kuralı: Normal kullanıcı sadece pending durumundaki kendi talebini iptal edebilir, 
    başkasınınkine erişirse 403 hatası dönmelidir.
    İş Kuralı: Teslim edilen (delivered) talepler kullanıcı tarafından iptal edilemez.
    """
    req = db.session.get(InventoryRequest, request_id)
    if not req:
        abort(404)
        
    is_manager_or_admin = current_user.role in ['admin', 'inventory_manager']
    
    # İş Kuralı: Normal kullanıcı başkasının talebine erişirse veya işlem yaparsa 403 döner
    if not is_manager_or_admin and req.user_id != current_user.id:
        abort(403)
        
    # İş Kuralı: Teslim edilen talepler KESİNLİKLE iptal edilemez
    if req.status == 'delivered':
        flash("Hata: Teslim edilmiş talepler iptal edilemez.", "danger")
        return redirect(url_for('requests.details', request_id=request_id))
        
    # İş Kuralı: Normal kullanıcı sadece pending durumundaki talebini iptal edebilir
    if not is_manager_or_admin and req.status != 'pending':
        flash(f"Hata: Normal kullanıcılar yalnızca beklemede (pending) olan taleplerini iptal edebilir. Mevcut durum: {req.status}", "danger")
        return redirect(url_for('requests.details', request_id=request_id))
        
    # Yönetici/Admin için sınır: Zaten iptal edilmiş veya reddedilmiş talepler iptal edilemez
    if is_manager_or_admin and req.status in ['cancelled', 'rejected']:
        flash(f"Hata: Zaten {req.status} durumundaki talepler iptal edilemez.", "danger")
        return redirect(url_for('requests.details', request_id=request_id))
        
    # Eğer onaylı bir talep iptal ediliyorsa stoğu geri iade et
    if req.status == 'approved':
        req.item.quantity += req.quantity
        req._status_change_notes = f"Onaylı talep iptal edildi. {req.quantity} adet stok envantere geri iade edildi. İşlemi yapan: {current_user.username}"
    else:
        req._status_change_notes = f"Talep iptal edildi. İşlemi yapan: {current_user.username}"
        
    req.status = 'cancelled'
    db.session.commit()
    
    flash(f"Talep #{req.id} iptal edildi.", "info")
    return redirect(url_for('requests.details', request_id=request_id))

from flask import Blueprint

requests_bp = Blueprint('requests', __name__)

from . import routes

from datetime import datetime
from sqlalchemy import String, Integer, ForeignKey, Text, DateTime, Boolean, event
from sqlalchemy.orm import Mapped, mapped_column, relationship
from flask_login import UserMixin, current_user
from sqlalchemy.orm.attributes import NO_VALUE
from werkzeug.security import generate_password_hash, check_password_hash
from app import db

class Department(db.Model):
    """
    Departmanları temsil eden model.
    Kullanıcılar bir departmana bağlıdır.
    """
    __tablename__ = 'departments'

    id: Mapped[int] = mapped_column(Integer, primary_key=True)
    name: Mapped[str] = mapped_column(String(100), unique=True, nullable=False)
    description: Mapped[str | None] = mapped_column(Text, nullable=True)

    # İlişkiler: Bir departmanda birden çok kullanıcı olabilir
    users: Mapped[list['User']] = relationship('User', back_populates='department')

    def __repr__(self) -> str:
        return f"<Department {self.name}>"


class User(db.Model, UserMixin):
    """
    Sistem kullanıcılarını temsil eden model.
    """
    __tablename__ = 'users'

    id: Mapped[int] = mapped_column(Integer, primary_key=True)
    username: Mapped[str] = mapped_column(String(50), unique=True, nullable=False)
    email: Mapped[str] = mapped_column(String(120), unique=True, nullable=False)
    password_hash: Mapped[str] = mapped_column(String(255), nullable=False)
    role: Mapped[str] = mapped_column(String(20), default='user')  # user, inventory_manager, admin
    created_at: Mapped[datetime] = mapped_column(DateTime, default=datetime.utcnow)
    
    # Departman ilişkisi (Foreign Key)
    department_id: Mapped[int | None] = mapped_column(ForeignKey('departments.id'), nullable=True)

    # İlişkiler
    department: Mapped['Department'] = relationship('Department', back_populates='users')
    requests: Mapped[list['InventoryRequest']] = relationship('InventoryRequest', back_populates='user')
    logs_changed: Mapped[list['RequestLog']] = relationship('RequestLog', back_populates='operator')

    # Şifre Yönetimi ve Hash'leme İş Kuralları
    def set_password(self, password: str) -> None:
        """Gelen açık şifreyi güvenli bir şekilde hash'leyerek kaydeder."""
        self.password_hash = generate_password_hash(password)

    def check_password(self, password: str) -> bool:
        """Girilen şifrenin hash karşılığını veritabanındakiyle karşılaştırır."""
        return check_password_hash(self.password_hash, password)

    def __repr__(self) -> str:
        return f"<User {self.username} (Role: {self.role})>"


class Category(db.Model):
    """
    Envanter kalemlerinin kategorilerini temsil eden model.
    """
    __tablename__ = 'categories'

    id: Mapped[int] = mapped_column(Integer, primary_key=True)
    name: Mapped[str] = mapped_column(String(100), unique=True, nullable=False)
    description: Mapped[str | None] = mapped_column(Text, nullable=True)

    # İlişkiler: Bir kategoride birden çok envanter kalemi olabilir
    items: Mapped[list['InventoryItem']] = relationship('InventoryItem', back_populates='category')

    def __repr__(self) -> str:
        return f"<Category {self.name}>"


class InventoryItem(db.Model):
    """
    Sistemdeki envanter kalemlerini temsil eden model.
    """
    __tablename__ = 'inventory_items'

    id: Mapped[int] = mapped_column(Integer, primary_key=True)
    name: Mapped[str] = mapped_column(String(100), nullable=False)
    description: Mapped[str | None] = mapped_column(Text, nullable=True)
    quantity: Mapped[int] = mapped_column(Integer, default=0) # Miktar negatif olamaz kuralı
    critical_stock_level: Mapped[int] = mapped_column(Integer, default=5)
    location: Mapped[str | None] = mapped_column(String(100), nullable=True)
    created_at: Mapped[datetime] = mapped_column(DateTime, default=datetime.utcnow)
    updated_at: Mapped[datetime] = mapped_column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)
    
    # Kategori ilişkisi (Foreign Key)
    category_id: Mapped[int] = mapped_column(ForeignKey('categories.id'), nullable=False)

    # İlişkiler
    category: Mapped['Category'] = relationship('Category', back_populates='items')
    requests: Mapped[list['InventoryRequest']] = relationship('InventoryRequest', back_populates='item')

    # İş Kuralı: Kritik stok seviyesi mantığı (quantity <= critical_stock_level)
    @property
    def is_critical(self) -> bool:
        """Stok miktarının kritik limitin altında veya limit değerinde olup olmadığını denetler."""
        return self.quantity <= self.critical_stock_level

    def __repr__(self) -> str:
        return f"<InventoryItem {self.name} (Qty: {self.quantity}/{self.critical_stock_level})>"


class InventoryRequest(db.Model):
    """
    Kullanıcıların envanter taleplerini temsil eden model.
    """
    __tablename__ = 'inventory_requests'

    id: Mapped[int] = mapped_column(Integer, primary_key=True)
    quantity: Mapped[int] = mapped_column(Integer, nullable=False)
    status: Mapped[str] = mapped_column(String(20), default='pending')  # pending, approved, rejected, delivered, cancelled
    request_note: Mapped[str | None] = mapped_column(Text, nullable=True)
    manager_note: Mapped[str | None] = mapped_column(Text, nullable=True)
    created_at: Mapped[datetime] = mapped_column(DateTime, default=datetime.utcnow)
    updated_at: Mapped[datetime] = mapped_column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)

    # İlişkiler için Foreign Key'ler
    user_id: Mapped[int] = mapped_column(ForeignKey('users.id'), nullable=False)
    item_id: Mapped[int] = mapped_column(ForeignKey('inventory_items.id'), nullable=False)

    # İlişkiler
    user: Mapped['User'] = relationship('User', back_populates='requests')
    item: Mapped['InventoryItem'] = relationship('InventoryItem', back_populates='requests')
    logs: Mapped[list['RequestLog']] = relationship(
        'RequestLog', 
        back_populates='request', 
        cascade='all, delete-orphan'
    )

    def __repr__(self) -> str:
        return f"<InventoryRequest {self.id} - User: {self.user_id} - Item: {self.item_id} - Qty: {self.quantity} - Status: {self.status}>"


class RequestLog(db.Model):
    """
    Taleplerin durum değişikliklerini loglayan audit model.
    """
    __tablename__ = 'request_logs'

    id: Mapped[int] = mapped_column(Integer, primary_key=True)
    old_status: Mapped[str | None] = mapped_column(String(20), nullable=True)
    new_status: Mapped[str] = mapped_column(String(20), nullable=False)
    note: Mapped[str | None] = mapped_column(Text, nullable=True)
    created_at: Mapped[datetime] = mapped_column(DateTime, default=datetime.utcnow)

    # İlişkiler için Foreign Key'ler
    request_id: Mapped[int] = mapped_column(ForeignKey('inventory_requests.id'), nullable=False)
    changed_by: Mapped[int | None] = mapped_column(ForeignKey('users.id'), nullable=True)

    # İlişkiler
    request: Mapped['InventoryRequest'] = relationship('InventoryRequest', back_populates='logs')
    operator: Mapped['User'] = relationship('User', back_populates='logs_changed')

    def __repr__(self) -> str:
        return f"<RequestLog id={self.id} req_id={self.request_id} {self.old_status} -> {self.new_status}>"


# ==========================================
# Otomatik Loglama Tetikleyicileri (Event Listeners)
# ==========================================
@event.listens_for(InventoryRequest.status, 'set')
def auto_log_request_status_change(target: InventoryRequest, value: str, oldvalue: str, initiator) -> None:
    """
    SQLAlchemy Event Listener: InventoryRequest modelinin 'status' niteliği her değiştiğinde tetiklenir.
    Eski ve yeni durumları karşılaştırarak otomatik olarak bir RequestLog kaydı oluşturur.
    """
    if oldvalue == value:
        return

    custom_notes = getattr(target, '_status_change_notes', None)

    if oldvalue == NO_VALUE:
        # Eğer zaten yaratılış logu init listener tarafından oluşturulduysa, mükerrer kaydı engelle
        if target.logs:
            return
        old_status_str = None
        log_notes = custom_notes or f"Talep oluşturuldu. İlk durum: '{value}' olarak belirlendi."
    else:
        old_status_str = oldvalue
        log_notes = custom_notes or f"Talep durumu '{oldvalue}' değerinden '{value}' değerine güncellendi."

    # İşlemi yapan kullanıcıyı g context veya target attribute üzerinden çekiyoruz
    operator_id = getattr(target, '_changed_by', None)
    if not operator_id and current_user and current_user.is_authenticated:
        operator_id = current_user.id

    log_entry = RequestLog(
        old_status=old_status_str,
        new_status=value,
        note=log_notes,
        changed_by=operator_id
    )
    target.logs.append(log_entry)


@event.listens_for(InventoryRequest, 'init')
def auto_log_request_creation(target: InventoryRequest, args, kwargs) -> None:
    """
    SQLAlchemy Event Listener: InventoryRequest nesnesi Python'da yaratıldığında (init) tetiklenir.
    Talep oluşturulduğunda başlangıç durumunu otomatik olarak loglar.
    """
    initial_status = kwargs.get('status', 'pending')
    custom_notes = kwargs.get('_status_change_notes', None)
    
    operator_id = kwargs.get('changed_by', None)
    if not operator_id and current_user and current_user.is_authenticated:
        operator_id = current_user.id
        
    log_entry = RequestLog(
        old_status=None,
        new_status=initial_status,
        note=custom_notes or f"Talep oluşturuldu. İlk durum: '{initial_status}' olarak belirlendi.",
        changed_by=operator_id
    )
    target.logs.append(log_entry)

{% extends "base.html" %}

{% block title %}İşlem Geçmişi (Audit Logs) - Admin Panel{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-text me-2 text-warning"></i>İşlem Geçmişi (Audit Logs)</h2>
    <div>
        <a href="{{ url_for('admin.users_list') }}" class="btn btn-outline-primary">
            <i class="bi bi-people-fill me-1"></i> Kullanıcı Yönetimi
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Zaman</th>
                        <th>Talep ID</th>
                        <th>Değişikliği Yapan</th>
                        <th>Eski Durum</th>
                        <th>Yeni Durum</th>
                        <th class="pe-4">Detay / Not</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in logs %}
                    <tr>
                        <td class="ps-4 text-muted small">{{ log.created_at.strftime('%Y-%m-%d %H:%M:%S') }}</td>
                        <td>
                            <a href="{{ url_for('requests.details', request_id=log.request_id) }}" class="badge bg-secondary text-decoration-none">
                                Talep #{{ log.request_id }}
                            </a>
                        </td>
                        <td>
                            {% if log.operator %}
                                <strong>{{ log.operator.username }}</strong>
                                <span class="badge bg-light text-dark border small">{{ log.operator.role|upper }}</span>
                            {% else %}
                                <span class="text-muted small">Sistem</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if log.old_status %}
                                {% if log.old_status == 'pending' %}
                                    <span class="badge bg-warning text-dark">Beklemede</span>
                                {% elif log.old_status == 'approved' %}
                                    <span class="badge bg-success">Onaylandı</span>
                                {% elif log.old_status == 'rejected' %}
                                    <span class="badge bg-danger">Reddedildi</span>
                                {% elif log.old_status == 'delivered' %}
                                    <span class="badge bg-info text-dark">Teslim Edildi</span>
                                {% elif log.old_status == 'cancelled' %}
                                    <span class="badge bg-secondary">İptal Edildi</span>
                                {% endif %}
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if log.new_status == 'pending' %}
                                <span class="badge bg-warning text-dark">Beklemede</span>
                            {% elif log.new_status == 'approved' %}
                                <span class="badge bg-success">Onaylandı</span>
                            {% elif log.new_status == 'rejected' %}
                                <span class="badge bg-danger">Reddedildi</span>
                            {% elif log.new_status == 'delivered' %}
                                <span class="badge bg-info text-dark">Teslim Edildi</span>
                            {% elif log.new_status == 'cancelled' %}
                                <span class="badge bg-secondary">İptal Edildi</span>
                            {% endif %}
                        </td>
                        <td class="pe-4 text-muted small">{{ log.note or '-' }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Henüz kayıtlı bir audit logu bulunmamaktadır.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
