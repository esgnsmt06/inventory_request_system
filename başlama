@api_bp.route('/v1/items', methods=['GET'])
def get_items():
    """
    Tüm envanter kalemlerini JSON formatında döner.
    """
    items = db.session.scalars(db.select(InventoryItem)).all()
    
    serialized_items = []
    for item in items:
        serialized_items.append({
            'id': item.id,
            'name': item.name,
            'category': item.category.name,
            'quantity': item.quantity,
            'critical_stock_level': item.critical_stock_level,
            'status': 'critical' if item.is_critical else 'available'
        })
        
    return jsonify(serialized_items)

@api_bp.route('/v1/items/<int:item_id>', methods=['GET'])
def get_item(item_id):
    """
    Belirli bir envanter kalemini JSON formatında döner.
    """
    item = db.session.get(InventoryItem, item_id)
    if not item:
        return jsonify({"error": "Ürün bulunamadı"}), 404
        
    return jsonify({
        'id': item.id,
        'name': item.name,
        'category': item.category.name,
        'quantity': item.quantity,
        'critical_stock_level': item.critical_stock_level,
        'status': 'critical' if item.is_critical else 'available'
    })

@api_bp.route('/v1/requests/my', methods=['GET'])
@login_required
def get_my_requests():
    """
    Giriş yapan kullanıcının kendi taleplerini JSON formatında döner.
    Dışarıya KESİNLİKLE şifre hash'i sızdırmaz.
    """
    requests = db.session.scalars(
        db.select(InventoryRequest).where(InventoryRequest.user_id == current_user.id)
    ).all()
    
    serialized_requests = []
    for req in requests:
        serialized_requests.append({
            'id': req.id,
