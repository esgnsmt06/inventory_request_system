{% block title %}Giriş Yap - Envanter & Talep Takip Sistemi{% endblock %}

{% block content %}
<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5">
        <div class="card p-4 shadow-lg border-0 rounded-4">
            <div class="text-center mb-4">
                <i class="bi bi-box-arrow-in-right text-primary display-4"></i>
                <h3 class="mt-2 font-weight-bold">Sisteme Giriş</h3>
                <p class="text-muted small">Lütfen kimlik bilgilerinizi giriniz</p>
            </div>
            
            <form method="POST" action="">
                {{ form.hidden_tag() }}
                
                <div class="mb-3">
                    <label class="form-label font-weight-bold">{{ form.username.label.text }}</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        {{ form.username(class="form-control" + (" is-invalid" if form.username.errors else ""), placeholder="Kullanıcı adınızı girin") }}
                    </div>
                    {% for error in form.username.errors %}
                        <div class="text-danger small mt-1">{{ error }}</div>
                    {% endfor %}
                </div>
                
                <div class="mb-4">
                    <label class="form-label font-weight-bold">{{ form.password.label.text }}</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        {{ form.password(class="form-control" + (" is-invalid" if form.password.errors else ""), placeholder="Şifrenizi girin") }}
                    </div>
                    {% for error in form.password.errors %}
                        <div class="text-danger small mt-1">{{ error }}</div>
                    {% endfor %}
                </div>
                
                <div class="d-grid mb-3">
                    {{ form.submit(class="btn btn-primary btn-lg rounded-3") }}
                </div>
            </form>
            
            <div class="text-center mt-3">
                <p class="text-muted small mb-0">Hesabınız yok mu? <a href="{{ url_for('auth.register') }}" class="text-decoration-none">Şimdi Kayıt Olun</a></p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

