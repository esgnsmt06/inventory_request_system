{% extends "base.html" %}

{% block title %}İşlem Geçmişi (Audit Logs) - Admin Panel{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-text me-2 text-warning"></i>İşlem Geçmişi (Audit Logs)</h2>
    <div>
        <a href="{{ url_for('admin.users_list') }}" class="btn btn-outline-primary">
            <i class="bi bi-people-fill me-1"></i> Kullanıcı Yönetimi
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Zaman</th>
                        <th>Talep ID</th>
                        <th>Değişikliği Yapan</th>
                        <th>Eski Durum</th>
                        <th>Yeni Durum</th>
                        <th class="pe-4">Detay / Not</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in logs %}
                    <tr>
                        <td class="ps-4 text-muted small">{{ log.created_at.strftime('%Y-%m-%d %H:%M:%S') }}</td>
                        <td>
                            <a href="{{ url_for('requests.details', request_id=log.request_id) }}" class="badge bg-secondary text-decoration-none">
                                Talep #{{ log.request_id }}
                            </a>
                        </td>
                        <td>
                            {% if log.operator %}
                                <strong>{{ log.operator.username }}</strong>
                                <span class="badge bg-light text-dark border small">{{ log.operator.role|upper }}</span>
                            {% else %}
                                <span class="text-muted small">Sistem</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if log.old_status %}
                                {% if log.old_status == 'pending' %}
                                    <span class="badge bg-warning text-dark">Beklemede</span>
                                {% elif log.old_status == 'approved' %}
                                    <span class="badge bg-success">Onaylandı</span>
                                {% elif log.old_status == 'rejected' %}
                                    <span class="badge bg-danger">Reddedildi</span>
                                {% elif log.old_status == 'delivered' %}
                                    <span class="badge bg-info text-dark">Teslim Edildi</span>
                                {% elif log.old_status == 'cancelled' %}
                                    <span class="badge bg-secondary">İptal Edildi</span>
                                {% endif %}
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if log.new_status == 'pending' %}
                                <span class="badge bg-warning text-dark">Beklemede</span>
                            {% elif log.new_status == 'approved' %}
                                <span class="badge bg-success">Onaylandı</span>
                            {% elif log.new_status == 'rejected' %}
                                <span class="badge bg-danger">Reddedildi</span>
                            {% elif log.new_status == 'delivered' %}
                                <span class="badge bg-info text-dark">Teslim Edildi</span>
                            {% elif log.new_status == 'cancelled' %}
                                <span class="badge bg-secondary">İptal Edildi</span>
                            {% endif %}
                        </td>
                        <td class="pe-4 text-muted small">{{ log.note or '-' }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Henüz kayıtlı bir audit logu bulunmamaktadır.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% extends "base.html" %}

{% block title %}Kullanıcı Yönetimi - Admin Panel{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people-fill me-2 text-primary"></i>Kullanıcı Yönetimi</h2>
    <div>
        <a href="{{ url_for('admin.audit_logs') }}" class="btn btn-outline-secondary">
            <i class="bi bi-journal-text me-1"></i> Audit Günlükleri
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Kullanıcı Adı</th>
                        <th>E-posta</th>
                        <th>Departman</th>
                        <th>Rol</th>
                        <th class="pe-4 text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td class="ps-4">{{ user.id }}</td>
                        <td>
                            <strong>{{ user.username }}</strong>
                            {% if user.id == current_user.id %}
                                <span class="badge bg-secondary ms-1">Siz</span>
                            {% endif %}
                        </td>
                        <td>{{ user.email }}</td>
                        <td>
                            {% if user.department %}
                                <span class="badge bg-light text-dark border"><i class="bi bi-building me-1"></i>{{ user.department.name }}</span>
                            {% else %}
                                <span class="text-muted small">Yok</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if user.role == 'admin' %}
                                <span class="badge bg-danger">ADMIN</span>
                            {% elif user.role == 'inventory_manager' %}
                                <span class="badge bg-success">ENVANTER SORUMLUSU</span>
                            {% else %}
                                <span class="badge bg-primary">KULLANICI</span>
                            {% endif %}
                        </td>
                        <td class="pe-4 text-end">
                            {% if user.id != current_user.id %}
                            <form action="{{ url_for('admin.update_role', user_id=user.id) }}" method="POST" class="d-inline-block">
                                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
                                <div class="input-group input-group-sm">
                                    <select name="role" class="form-select form-select-sm" style="max-width: 150px;">
                                        <option value="user" {% if user.role == 'user' %}selected{% endif %}>Kullanıcı</option>
                                        <option value="inventory_manager" {% if user.role == 'inventory_manager' %}selected{% endif %}>Sorumlu</option>
                                        <option value="admin" {% if user.role == 'admin' %}selected{% endif %}>Admin</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        Güncelle
                                    </button>
                                </div>
                            </form>
                            {% else %}
                            <span class="text-muted small">Değiştirilemez</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

