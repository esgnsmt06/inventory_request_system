{% extends "base.html" %}

{% block title %}Dashboard - Envanter & Talep Takip Sistemi{% endblock %}

{% block content %}
<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 mb-1 text-gray-800">Hoş Geldiniz, {{ current_user.username }}</h1>
        <p class="text-muted">Envanter durumu ve kritik stok uyarılarına hızlı genel bakış.</p>
    </div>
</div>

<!-- Özet Kartları Grid'i -->
<div class="row g-3 mb-4">
    <!-- Toplam Ürün Kartı -->
    <div class="col-md-3">
        <div class="card h-100 p-3 bg-white border-start border-primary border-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-xs text-muted text-uppercase fw-bold mb-1">Toplam Ürün Çeşidi</div>
                    <div class="h3 mb-0 fw-bold text-dark">{{ total_items }}</div>
                </div>
                <div class="text-primary fs-1"><i class="bi bi-box"></i></div>
            </div>
        </div>
    </div>
    
    <!-- Toplam Talep Kartı -->
    <div class="col-md-3">
        <div class="card h-100 p-3 bg-white border-start border-success border-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-xs text-muted text-uppercase fw-bold mb-1">Toplam Talepler</div>
                    <div class="h3 mb-0 fw-bold text-dark">{{ total_requests }}</div>
                </div>
                <div class="text-success fs-1"><i class="bi bi-file-earmark-text"></i></div>
            </div>
        </div>
    </div>

    <!-- Kritik Stok Kartı -->
    <div class="col-md-3">
        <div class="card h-100 p-3 bg-white border-start border-danger border-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-xs text-muted text-uppercase fw-bold mb-1">Kritik Stoktaki Ürünler</div>
                    <div class="h3 mb-0 fw-bold text-danger">{{ critical_items_count }}</div>
                </div>
                <div class="text-danger fs-1"><i class="bi bi-exclamation-triangle-fill"></i></div>
            </div>
        </div>
    </div>

    <!-- Bekleyen Talepler Kartı -->
    <div class="col-md-3">
        <div class="card h-100 p-3 bg-white border-start border-warning border-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-xs text-muted text-uppercase fw-bold mb-1">Bekleyen Talepler</div>
                    <div class="h3 mb-0 fw-bold text-dark">{{ pending_requests_count }}</div>
                </div>
                <div class="text-warning fs-1"><i class="bi bi-clock-history"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Kritik Stok Seviyesindeki Ürünler Listesi -->
    <div class="col-lg-8 mb-4">
        <div class="card h-100">
            <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
                <h6 class="m-0 fw-bold text-danger"><i class="bi bi-exclamation-octagon-fill me-2"></i>Kritik Stok Uyarısı Veren Ürünler</h6>
                <span class="badge bg-danger rounded-pill">{{ critical_items|length }} Ürün</span>
            </div>
            <div class="card-body">
                {% if critical_items %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Ürün Adı</th>
                                    <th>Kategori</th>
                                    <th class="text-center">Mevcut Stok</th>
                                    <th class="text-center">Kritik Seviye</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in critical_items %}
                                    <tr>
                                        <td><strong>{{ item.name }}</strong></td>
                                        <td>{{ item.category.name }}</td>
                                        <td class="text-center"><span class="badge bg-danger">{{ item.quantity }}</span></td>
                                        <td class="text-center">{{ item.critical_stock_level }}</td>
                                        <td>
                                            {% if item.quantity == 0 %}
                                                <span class="text-danger fw-bold"><i class="bi bi-x-circle-fill me-1"></i> Stok Tükendi</span>
                                            {% else %}
                                                <span class="text-warning fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> Kritik Seviyede</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-4">
                        <div class="text-success fs-1"><i class="bi bi-check-circle-fill"></i></div>
                        <p class="mt-2 mb-0 text-muted">Kritik stok seviyesinde ürün bulunmamaktadır. Her şey yolunda!</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Hızlı İşlemler Kartı -->
    <div class="col-lg-4 mb-4">
        <div class="card h-100">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 fw-bold text-dark"><i class="bi bi-lightning-charge-fill me-2 text-primary"></i>Hızlı İşlemler</h6>
            </div>
            <div class="card-body d-grid gap-3">
                <a href="{{ url_for('inventory.index') }}" class="btn btn-outline-primary p-3 text-start d-flex align-items-center">
                    <i class="bi bi-search fs-3 me-3"></i>
                    <div>
                        <div class="fw-bold">Envanterde Arama Yap</div>
                        <small class="text-muted">Ürünleri arayın, miktar ve kategorileri listeleyin.</small>
                    </div>
                </a>
